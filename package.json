{
  "name": "googleforms-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "server": "npm --prefix server run dev",
    "client": "npm --prefix client/client run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
